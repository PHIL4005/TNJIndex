# 环境变量与密钥（不入 Git）
.env
.env.*

# 数据目录（不入 Git）
data/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# 虚拟环境
.venv/

# 数据库
*.db
*.sqlite3

# 编辑器
.idea/
.vscode/
*.swp
.DS_Store

# uv
.python-version

# Node（任意子目录；显式写出 frontend 以免子项目误 init 时漏配）
node_modules/
frontend/node_modules/

# Vite 缓存
frontend/.vite/
frontend/dist/

# 爬虫本地 cookie（勿提交）
scrapers/tieba_cookie.txt
scrapers/*_cookie.txt

# 前端生产构建输出（frontend/vite.config.ts → ../backend/static）
backend/static/
